<?xml version="1.0" encoding="UTF-8"?>
<hibernate-configuration>
	<session-factory>
		<property name="connection.driver_class">com.mysql.cj.jdbc.Driver</property>
		<property name="connection.url">jdbc:mysql://localhost:3306/brad</property>
		<property name="connection.username">root</property>
		<property name="connection.password">root</property>

		<property name="hibernate.show_sql">true</property>
		<property name="hibernate.format_sql">true</property>

		<mapping class="tw.brad.entity.Test"></mapping>
		<mapping class="tw.brad.entity.Member"></mapping>
		<mapping class="tw.brad.entity.MemberInfo"></mapping>
		<mapping class="tw.brad.entity.Order"></mapping>
		<mapping class="tw.brad.entity.OrderItem"></mapping>
		<mapping class="tw.brad.entity.Student"></mapping>
		<mapping class="tw.brad.entity.Course"></mapping>

	</session-factory>
</hibernate-configuration>